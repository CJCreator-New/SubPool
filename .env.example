# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Service Role Key — used ONLY in Edge Functions / server-side scripts
# NEVER prefix with VITE_ — it must never reach the browser
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Sentry (optional but recommended for production) ─────────────────────────
# Create a React project at https://sentry.io → Settings → Projects → Client Keys
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>

# ─── Stripe (required for real payments) ──────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_ / sk_test_ during development; switch to live keys in production
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-publishable-key>
# STRIPE_SECRET_KEY=sk_test_<your-secret-key>         ← Edge Functions only, never VITE_
# STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>   ← After creating webhook endpoint
